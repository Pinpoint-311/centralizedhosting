# Environment for self-hosted {{ tenant.name }} — generated at offload.
# These are the values your instance was running with on the managed platform,
# so nothing breaks at cutover (the same SECRET_KEY means existing encrypted
# data still decrypts). ROTATE every secret below once you're live on your own
# infrastructure — the state generated these and should no longer be trusted.

DB_USER=township
DB_NAME={{ tenant.db_name or 'pp311' }}
DOMAIN={{ external_host }}
MANAGED_MODE=false
REQUIRE_KMS=false

{% for key, value in secrets | dictsort -%}
{{ key }}={{ value }}
{% endfor -%}
