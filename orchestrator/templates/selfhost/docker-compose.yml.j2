# Standalone (self-hosted) Pinpoint 311 for {{ tenant.name }}.
# Generated by the state's control plane for offload — you now run this on your
# OWN servers. Un-managed: no provisioning token, no state control channel, you
# own every key. Rotate the secrets in .env after cutover.
services:
  db:
    image: ghcr.io/baosystems/postgis:15-3.3
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${DB_USER}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
      POSTGRES_DB: ${DB_NAME}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: [ "CMD-SHELL", "pg_isready -U ${DB_USER}" ]
      interval: 5s
      timeout: 5s
      retries: 5
    security_opt:
      - no-new-privileges:true

  redis:
    image: redis:7-alpine
    restart: unless-stopped
    command: redis-server --maxmemory 200mb --maxmemory-policy allkeys-lru
    healthcheck:
      test: [ "CMD", "redis-cli", "ping" ]
      interval: 5s
      timeout: 5s
      retries: 5
    security_opt:
      - no-new-privileges:true

  backend:
    image: {{ backend_ref }}
    restart: unless-stopped
    command: uvicorn app.main:app --host 0.0.0.0 --port 8000
    env_file: .env
    environment:
      DATABASE_URL: postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@db/${DB_NAME}
      REDIS_URL: redis://redis:6379/0
      # Self-hosted: you are no longer in managed mode and there is no state
      # control plane. You own all settings and keys.
      MANAGED_MODE: "false"
      REQUIRE_KMS: "false"
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy
    security_opt:
      - no-new-privileges:true

  worker:
    image: {{ backend_ref }}
    restart: unless-stopped
    command: celery -A app.core.celery_app worker --beat --loglevel=info
    env_file: .env
    environment:
      DATABASE_URL: postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@db/${DB_NAME}
      REDIS_URL: redis://redis:6379/0
      MANAGED_MODE: "false"
      REQUIRE_KMS: "false"
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy
    security_opt:
      - no-new-privileges:true

  frontend:
    image: {{ frontend_ref }}
    restart: unless-stopped
    environment:
      - VITE_API_URL=/api
    security_opt:
      - no-new-privileges:true

  # Bundled edge proxy + automatic TLS (you control the domain now).
  caddy:
    image: caddy:2-alpine
    restart: unless-stopped
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data
    depends_on:
      - backend
      - frontend

volumes:
  postgres_data:
  caddy_data:
