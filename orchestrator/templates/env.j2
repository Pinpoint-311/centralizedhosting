# Rendered by the Pinpoint 311 orchestrator — platform-brokered values only.
#
# Contains the infrastructure keys the state always owns PLUS any assignable
# service keys this town has assigned to the state (its key-responsibility
# matrix). Keys the town owns are NOT here — the town enters those in its own
# instance and they never touch the panel.
DB_USER=township
DB_NAME={{ tenant.db_name }}
DOMAIN={{ external_host }}
{% for key, value in secrets | dictsort -%}
{{ key }}={{ value }}
{% endfor -%}
