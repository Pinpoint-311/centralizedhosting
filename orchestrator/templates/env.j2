# Rendered by the Pinpoint 311 orchestrator — platform-managed values only.
# Tenant-managed keys (AI/translation/identity/SMTP/branding) are entered by
# the town inside its own instance and never appear here.
DB_USER=township
DB_NAME={{ tenant.db_name }}
DB_PASSWORD={{ secrets.get("DB_PASSWORD", "") }}
SECRET_KEY={{ secrets.get("SECRET_KEY", "") }}
PROVISIONING_TOKEN={{ secrets.get("PROVISIONING_TOKEN", "") }}
DOMAIN={{ external_host }}
GOOGLE_CLOUD_PROJECT={{ secrets.get("GOOGLE_CLOUD_PROJECT", "") }}
KMS_KEY_RING={{ secrets.get("KMS_KEY_RING", "") }}
KMS_KEY_ID={{ secrets.get("KMS_KEY_ID", "") }}
KMS_LOCATION={{ secrets.get("KMS_LOCATION", "") }}
