# Rendered by the Pinpoint 311 orchestrator — do not edit by hand.
# Town: {{ tenant.name }} ({{ tenant.slug }})  Version: {{ version }}
#
# Hosted-mode hardening (ORCHESTRATOR_PLAN.md A2): pinned image tags, no
# Docker socket mount, no watchtower. Upgrades arrive only via the panel.

services:
  db:
    image: ghcr.io/baosystems/postgis:15-3.3
    restart: unless-stopped
    environment:
      POSTGRES_USER: ${DB_USER}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
      POSTGRES_DB: ${DB_NAME}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    security_opt:
      - no-new-privileges:true
    healthcheck:
      test: [ "CMD-SHELL", "pg_isready -U ${DB_USER}" ]
      interval: 5s
      timeout: 5s
      retries: 5
    logging:
      driver: "json-file"
      options:
        max-size: "50m"
        max-file: "3"

  redis:
    image: redis:7-alpine
    restart: unless-stopped
    command: redis-server --maxmemory 200mb --maxmemory-policy allkeys-lru
    healthcheck:
      test: [ "CMD", "redis-cli", "ping" ]
      interval: 5s
      timeout: 5s
      retries: 5
    security_opt:
      - no-new-privileges:true
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  backend:
    image: {{ backend_image }}:{{ version }}
    restart: unless-stopped
    command: uvicorn app.main:app --host 0.0.0.0 --port 8000
    environment:
      DATABASE_URL: postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@db/${DB_NAME}
      REDIS_URL: redis://redis:6379/0
      SECRET_KEY: ${SECRET_KEY}
      MANAGED_MODE: "true"
      REQUIRE_KMS: "true"
      PROVISIONING_TOKEN: ${PROVISIONING_TOKEN}
      APP_VERSION: "{{ version }}"
      DOMAIN: ${DOMAIN}
      GOOGLE_CLOUD_PROJECT: ${GOOGLE_CLOUD_PROJECT:-}
      KMS_KEY_RING: ${KMS_KEY_RING:-}
      KMS_KEY_ID: ${KMS_KEY_ID:-}
      KMS_LOCATION: ${KMS_LOCATION:-}
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy
    ports:
      # Loopback only — public traffic reaches the town via the host Caddy.
      - "127.0.0.1:{{ tenant.backend_port }}:8000"
    healthcheck:
      test: [ "CMD", "curl", "-f", "http://localhost:8000/api/health/quick" ]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
    security_opt:
      - no-new-privileges:true
    logging:
      driver: "json-file"
      options:
        max-size: "50m"
        max-file: "3"

  worker:
    image: {{ backend_image }}:{{ version }}
    restart: unless-stopped
    command: celery -A app.core.celery_app worker --beat --loglevel=info
    environment:
      DATABASE_URL: postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@db/${DB_NAME}
      REDIS_URL: redis://redis:6379/0
      SECRET_KEY: ${SECRET_KEY}
      MANAGED_MODE: "true"
      REQUIRE_KMS: "true"
      GOOGLE_CLOUD_PROJECT: ${GOOGLE_CLOUD_PROJECT:-}
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy
    security_opt:
      - no-new-privileges:true
    logging:
      driver: "json-file"
      options:
        max-size: "20m"
        max-file: "3"

  frontend:
    image: {{ frontend_image }}:{{ version }}
    restart: unless-stopped
    ports:
      - "127.0.0.1:{{ tenant.frontend_port }}:80"
    environment:
      - VITE_API_URL=/api
    security_opt:
      - no-new-privileges:true
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

volumes:
  postgres_data:
